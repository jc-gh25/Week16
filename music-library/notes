Below is a concise roadmap for Flyway migrations, Dockerisation, and deployment of the whole stack (MySQL + Spring Boot + Lumo). Feel free to cherry‑pick the pieces you need for your boot‑camp submission.

5.1 Flyway – Database version control
Add the dependency (already present in a typical Spring Boot starter, but double‑check):

<!-- pom.xml -->
<dependency>
    <groupId>org.flywaydb</groupId>
    <artifactId>flyway-core</artifactId>
</dependency>
Copy
Folder layout (default src/main/resources/db/migration).
Place every migration script there, naming them V<major>_<minor>__<description>.sql. Example:

src/main/resources/db/migration/
├─ V1_0__create_schema.sql
├─ V1_1__add_catalog_number_unique.sql
└─ V1_2__add_cover_image_url.sql
Copy
Sample migration scripts

-- V1_0__create_schema.sql
CREATE TABLE artist (
    artist_id BIGINT AUTO_INCREMENT PRIMARY KEY,
    name VARCHAR(255) NOT NULL,
    description TEXT,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP
);

CREATE TABLE genre (
    genre_id BIGINT AUTO_INCREMENT PRIMARY KEY,
    name VARCHAR(100) NOT NULL,
    description TEXT,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP
);

CREATE TABLE album (
    album_id BIGINT AUTO_INCREMENT PRIMARY KEY,
    title VARCHAR(255) NOT NULL,
    release_date DATE,
    cover_image_url VARCHAR(255),
    track_count INT,
    catalog_number VARCHAR(50) UNIQUE,
    artist_id BIGINT NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    CONSTRAINT fk_album_artist FOREIGN KEY (artist_id) REFERENCES artist(artist_id)
);

CREATE TABLE album_genre (
    album_id BIGINT NOT NULL,
    genre_id BIGINT NOT NULL,
    PRIMARY KEY (album_id, genre_id),
    CONSTRAINT fk_ag_album FOREIGN KEY (album_id) REFERENCES album(album_id) ON DELETE CASCADE,
    CONSTRAINT fk_ag_genre FOREIGN KEY (genre_id) REFERENCES genre(genre_id) ON DELETE CASCADE
);
Copy
-- V1_1__add_catalog_number_unique.sql
ALTER TABLE album ADD CONSTRAINT uq_album_catalog UNIQUE (catalog_number);
Copy
-- V1_2__add_cover_image_url.sql
ALTER TABLE album ADD COLUMN cover_image_url VARCHAR(255);
Copy
Configuration (application.yaml)

spring:
  flyway:
    enabled: true
    locations: classpath:db/migration
    baseline-on-migrate: true   # useful when you start with an existing DB
Copy
When the app starts, Flyway will automatically apply any pending scripts.
In tests you already have an H2 DB with flyway.enabled: true – the same migrations will run against the in‑memory DB, keeping test and prod schemas identical.

5.2 Docker – Containerise the whole stack
5.2.1 Dockerfile for the Spring Boot app
# ---- Build stage ---------------------------------------------------------
FROM maven:3.9-eclipse-temurin-17 AS build
WORKDIR /app
COPY pom.xml .
COPY src ./src
RUN mvn -B -DskipTests clean package

# ---- Runtime stage -------------------------------------------------------
FROM eclipse-temurin:17-jre-alpine
ARG JAR_FILE=/app/target/*.jar
COPY --from=build ${JAR_FILE} app.jar
EXPOSE 8080
ENTRYPOINT ["java","-jar","/app.jar"]
Copy
Build image: docker build -t music-library:latest .
Run container (linking to a MySQL container, see next step).
5.2.2 Docker‑Compose (MySQL + app)
version: "3.9"

services:
  mysql:
    image: mysql:8.0
    environment:
      MYSQL_DATABASE: music_library
      MYSQL_USER: music_library
      MYSQL_PASSWORD: music_library
      MYSQL_ROOT_PASSWORD: rootpw
    ports:
      - "3306:3306"
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost"]
      interval: 5s
      timeout: 2s
      retries: 5
    volumes:
      - mysql-data:/var/lib/mysql

  app:
    image: music-library:latest
    depends_on:
      mysql:
        condition: service_healthy
    environment:
      SPRING_DATASOURCE_URL: jdbc:mysql://mysql:3306/music_library?useSSL=false&allowPublicKeyRetrieval=true
      SPRING_DATASOURCE_USERNAME: music_library
      SPRING_DATASOURCE_PASSWORD: music_library
      SPRING_JPA_HIBERNATE_DDL_AUTO: none   # Flyway will manage schema
    ports:
      - "8080:8080"

volumes:
  mysql-data:
Copy
Start everything: docker-compose up -d
The app will run on http://localhost:8080/api/... and will automatically invoke Flyway on startup.


Common deployment checklist

Externalise all secrets – never hard‑code DB passwords. Use environment variables or a secret manager (AWS Secrets Manager, GCP Secret Manager, etc.).
Turn on Flyway – the first container start will create/upgrade the schema automatically.
Health‑check endpoint – expose /actuator/health (Spring Boot Actuator) so the orchestrator can detect a healthy pod/container.
Logging – configure logging.file.name=logs/app.log or ship logs to a centralized system (ELK, Loki).
Graceful shutdown – Spring Boot already handles SIGTERM; ensure the container’s stop_grace_period is long enough for the embedded Tomcat to close connections.

