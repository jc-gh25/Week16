CREATE DATABASE IF NOT EXISTS music_library;
USE music_library;

-- -------------------------------------------------
-- Artist
-- -------------------------------------------------
CREATE TABLE Artist (
    artist_id   INT AUTO_INCREMENT PRIMARY KEY,
    name        VARCHAR(255) NOT NULL,
    bio      TEXT,
    created_at  TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at  TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP
);

-- -------------------------------------------------
-- Album
-- -------------------------------------------------
CREATE TABLE Album (
    album_id    INT AUTO_INCREMENT PRIMARY KEY,
    title       VARCHAR(255) NOT NULL,
    release_year YEAR,
    artist_id   INT NOT NULL,
    created_at  TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at  TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    CONSTRAINT fk_album_artist
        FOREIGN KEY (artist_id) REFERENCES Artist(artist_id)
        ON DELETE RESTRICT ON UPDATE CASCADE
);

-- -------------------------------------------------
-- Genre
-- -------------------------------------------------
CREATE TABLE Genre (
    genre_id    INT AUTO_INCREMENT PRIMARY KEY,
    name        VARCHAR(100) NOT NULL,
    description TEXT,
    created_at  TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at  TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP
);

-- -------------------------------------------------
-- Join table (snake_case version)
-- -------------------------------------------------
CREATE TABLE album_genre (
    album_id    INT NOT NULL,
    genre_id    INT NOT NULL,
    created_at  TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at  TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    PRIMARY KEY (album_id, genre_id),
    CONSTRAINT fk_ag_album
        FOREIGN KEY (album_id) REFERENCES Album(album_id)
        ON DELETE CASCADE ON UPDATE CASCADE,
    CONSTRAINT fk_ag_genre
        FOREIGN KEY (genre_id) REFERENCES Genre(genre_id)
        ON DELETE CASCADE ON UPDATE CASCADE
);

--

Things to keep in mind
No Song/Track table – You’ll only be able to store album‑level metadata (title, year, etc.). 
If you ever need per-track data (duration, composer, play count, etc.) you’ll have to 
add a Track table later and link it to Album.
Cascade rules – I used ON DELETE RESTRICT for Album → Artist (so you don’t accidentally delete 
an artist and lose all their albums). The join table cascades deletes, which is usually handy 
for cleaning up orphaned rows. Adjust to your project’s requirements.
Indexes – MySQL automatically indexes primary keys. 
Adding an index on Album.artist_id and on both FK columns of Album_Genre 
can improve query speed if the dataset grows.



